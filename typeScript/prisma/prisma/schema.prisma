generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://prisma:code2100@localhost:5432/postgres"
}

model User {
  id        Int      @id @default(autoincrement())
  lastname  String?
  email     String   @unique
  password  String
  fisrtname String
  createAt  DateTime @default(now())
}
